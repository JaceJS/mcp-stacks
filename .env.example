# Supabase
# Get these from: https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# App URL
# Used to build OAuth callback URLs for GitHub/Google sign-in
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Local Supabase (after `bun run db:start`)
# Copy values from output of `bunx supabase status`
# NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
# NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon key from supabase status>

# GitHub OAuth — Local (callback: http://localhost:54321/auth/v1/callback)
# Create at: github.com/settings/developers → OAuth Apps → New OAuth App
SUPABASE_AUTH_GITHUB_CLIENT_ID=your-github-client-id
SUPABASE_AUTH_GITHUB_SECRET=your-github-client-secret
